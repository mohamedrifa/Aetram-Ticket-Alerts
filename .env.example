APP_NAME=Aetram Ticket Support
API_BASE_URL=https://whook.aetramtrades.in
ATTACHMENT_BASE_URL=https://ticket.aetramtrades.in
API_CONNECT_TIMEOUT_SECONDS=15
API_RECEIVE_TIMEOUT_SECONDS=20
TICKET_POLLING_SECONDS=60
ANDROID_ALARM_INTERVAL_SECONDS=10
BACKGROUND_CHECK_MINUTES=15
ENABLE_BACKGROUND_CHECK=true

# Firebase public application configuration (not service-account secrets)
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=
FIREBASE_IOS_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_IOS_BUNDLE_ID=com.example.aetramTicketAlerts
